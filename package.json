{
  "name": "ts-refine",
  "description": "LS-based semantic refactoring for TypeScript: move files, rename exports, rewrite imports, and format to local conventions.",
  "version": "0.4.0",
  "author": "Kawanet",
  "bin": {
    "ts-refine": "./dist/ts-refine.cli.mjs"
  },
  "bugs": {
    "url": "https://github.com/kawanet/ts-refine/issues"
  },
  "dependencies": {
    "typescript": "~6.0.3"
  },
  "devDependencies": {
    "@rollup/plugin-alias": "^6.0.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-sucrase": "^5.1.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/node": "^24.10.0",
    "@typescript-eslint/parser": "^8.60.1",
    "eslint": "^10.4.1",
    "prettier": "^3.8.3",
    "rollup": "^4.61.0"
  },
  "engines": {
    "node": ">=22.18"
  },
  "exports": {
    ".": {
      "types": "./types/ts-refine.d.ts",
      "import": "./dist/ts-refine.mjs"
    }
  },
  "files": [
    "LICENSE",
    "README.md",
    "dist/ts-refine.mjs",
    "dist/ts-refine.cli.mjs",
    "types/*.d.ts"
  ],
  "homepage": "https://github.com/kawanet/ts-refine#readme",
  "keywords": [
    "knip",
    "language-service",
    "optimize-imports",
    "organize-imports",
    "prettier",
    "refactor",
    "stylistic",
    "ts-morph",
    "typescript"
  ],
  "license": "MIT",
  "main": "./dist/ts-refine.mjs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kawanet/ts-refine.git"
  },
  "scripts": {
    "build": "make -C builder",
    "eslint": "eslint .",
    "eslint:fix": "eslint --fix .",
    "fixpack": "fixpack",
    "prepack": "make -C builder is-buildable",
    "prepare": "make -C builder is-not-buildable 2> /dev/null || make -C builder clean all test",
    "prettier:check": "prettier --check .",
    "prettier:write": "prettier --write .",
    "test": "make -C builder test",
    "ts-refine": "node src/cli.ts imports && node src/cli.ts format",
    "ts-refine:check": "node src/cli.ts imports --check && node src/cli.ts format --check"
  },
  "type": "module",
  "types": "./types/ts-refine.d.ts"
}
